<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.lostandfound.controllers.RegisterController"
      styleClass="root-container" alignment="CENTER" spacing="0">

    <HBox styleClass="accent-stripe" maxWidth="Infinity"/>

    <VBox alignment="CENTER" VBox.vgrow="ALWAYS" spacing="0">
        <padding><Insets top="48" right="0" bottom="48" left="0"/></padding>

        <VBox alignment="CENTER" spacing="6">
            <Text text="📦  Lost &amp; Found" styleClass="title-text"/>
            <Text text="Create a new account"
                  style="-fx-font-size: 13px; -fx-fill: #A1A1AA;"/>
        </VBox>
        <VBox.margin><Insets bottom="32"/></VBox.margin>

        <VBox styleClass="form-card" maxWidth="440" minWidth="380" spacing="16" alignment="CENTER_LEFT">
            <Text text="Register Account"
                  style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-fill: #18181B; -fx-font-family: 'Segoe UI Semibold', Arial, sans-serif;"/>

            <VBox spacing="6">
                <Label text="Full Name *"/>
                <TextField fx:id="nameField" promptText="Enter your full name" maxWidth="Infinity"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Email Address *"/>
                <TextField fx:id="emailField" promptText="you@example.com" maxWidth="Infinity"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Phone Number"/>
                <TextField fx:id="phoneField" promptText="+91 9876543210" maxWidth="Infinity"/>
            </VBox>

            <HBox spacing="14">
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Password *"/>
                    <PasswordField fx:id="passwordField" promptText="Create password" maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Confirm Password *"/>
                    <PasswordField fx:id="confirmPasswordField" promptText="Repeat password" maxWidth="Infinity"/>
                </VBox>
            </HBox>

            <Button text="Create Account →" onAction="#handleRegister" maxWidth="Infinity" styleClass="primary-button">
                <VBox.margin><Insets top="4"/></VBox.margin>
            </Button>

            <HBox alignment="CENTER">
                <Hyperlink text="Already have an account? Login here." onAction="#handleGoToLogin"/>
            </HBox>
        </VBox>
    </VBox>

    <HBox alignment="CENTER" style="-fx-background-color: #18181B; -fx-padding: 12 0 12 0;">
        <Text text="Lost &amp; Found System  •  All rights reserved"
              style="-fx-fill: #52525B; -fx-font-size: 11px;"/>
    </HBox>
</VBox>
